---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug"

const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const last_posts = posts.slice(0, 3);
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Welcome to my space 👋</div>
    <div class="text-5xl font-bold">I'm Gagandeep Kundhal</div>
    <div class="text-3xl py-3 font-bold">Staff Engineer at Equinix</div>
    <div class="py-2">
      <text class="text-lg">
        I am a results-oriented Staff Engineer with extensive experience in front-end UI design and full-stack development. I specialize in building scalable Single Page Applications (SPA) and implementing complex architectural patterns. Explore my career journey and projects below.
      </text>
    </div>
    <div class="mt-8">
      <a class="btn" href="https://www.linkedin.com/in/gagandeepkundhal/" target="_blank"> Let's connect!</a>
      <a href="/cv" class="btn btn-outline ml-5"> View my CV</a>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-2">My last projects {"</>"}</div>
  </div>

  <HorizontalCard
    title="Personal Investment Module Redesign"
    img="/project_placeholder.webp"
    desc="Worked on redesigning the Personal Investment module for Fidelity International using Angular, Node.js, and MongoDB."
    url="/projects"
    badge="Fidelity"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Lanyon Travel Portal"
    img="/project_placeholder.webp"
    desc="Developed and maintained the Lanyon travel portal focusing on feature enhancements and performance."
    url="/projects"
    badge="Cybage"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Tech Data Retail Website"
    img="/project_placeholder.webp"
    desc="Enhanced the Tech Data retail website ensuring cross-browser compatibility and optimized UX."
    url="/projects"
    badge="HCL"
  />

  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">Latest from blog</div>
  </div>

  {
    last_posts.map((post) => (
      <>
        <HorizontalCard
          title={post.data.title}
          img={post.data.heroImage}
          desc={post.data.description}
          url={"/blog/" + createSlug(post.data.title, post.slug)}
          target="_self"
          badge={post.data.badge}
        />
        <div class="divider my-0" />
      </>
    ))
  }
</BaseLayout>
