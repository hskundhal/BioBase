---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";

// We'll use a simplified version of the layout for the landing page
// or just use BaseLayout and hide the sidebar later if needed.
---

<BaseLayout title="Biosite - Professional Resumes" includeSidebar={false}>
  <div class="pb-12 mt-5">
    <div class="text-5xl font-bold italic">Biosite</div>
    <div class="text-3xl py-3 font-bold">Resumes Portal</div>
    <div class="py-2">
      <text class="text-lg">
        Welcome to our professional space. Click on a profile below to view the full resume and projects.
      </text>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-10">
    <a href="/gagandeepkundhal" class="group">
      <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all duration-300 border border-base-300 group-hover:border-primary">
        <figure class="px-10 pt-10">
          <div class="avatar px-6">
            <div class="w-32 rounded-full ring ring-primary ring-offset-base-100 ring-offset-2">
              <img src="/profile.jpg" alt="Gagandeep Kundhal" />
            </div>
          </div>
        </figure>
        <div class="card-body items-center text-center">
          <h2 class="card-title text-2xl">Gagandeep Kundhal</h2>
          <p class="text-sm opacity-70">Staff Engineer at Equinix</p>
          <div class="card-actions mt-4">
            <button class="btn btn-primary">View Resume</button>
          </div>
        </div>
      </div>
    </a>

    <a href="/harpreetsingh" class="group">
      <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all duration-300 border border-base-300 group-hover:border-secondary">
        <figure class="px-10 pt-10">
          <div class="avatar px-6">
            <div class="w-32 rounded-full ring ring-secondary ring-offset-base-100 ring-offset-2">
              <img src="/harpreet.jpg" alt="Harpreet Singh" />
            </div>
          </div>
        </figure>
        <div class="card-body items-center text-center">
          <h2 class="card-title text-2xl">Harpreet Singh</h2>
          <p class="text-sm opacity-70">Senior Data Engineer</p>
          <div class="card-actions mt-4">
            <button class="btn btn-secondary">View Resume</button>
          </div>
        </div>
      </div>
    </a>
  </div>
</BaseLayout>
