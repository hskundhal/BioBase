---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout 
  title="Gagandeep Kundhal - Resume" 
  sideBarActiveItemID="cv" 
  profileImage="/profile.jpg" 
  profileName="Gagandeep Kundhal"
  profileLinkedin="https://www.linkedin.com/in/gagandeepkundhal/"
>
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Profile</div>
  </div>

  <div class="mb-10 text-justify">
    Results-oriented Staff Engineer with extensive experience in front-end UI design and full-stack development. Deep understanding of Design Patterns including Singleton, Factory, and Observer. Expert in building scalable Single Page Applications (SPA) using Angular, React, and Node.js. Proven track record in Agile environments, integrating complex Social Media APIs, and managing cloud deployments on AWS.
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Experience</div>
  </div>

  <div class="time-line-container mb-10">
    <TimeLineElement
      title="Staff Engineer"
      subtitle="From Jun 2023 to Present at Equinix"
    >
      Leading technical initiatives and architectural decisions as a Staff Engineer.
    </TimeLineElement>
    <TimeLineElement
      title="Principal Member Of Technical Staff"
      subtitle="From Mar 2021 to Jun 2023 at Oracle"
    >
      Developed large-scale enterprise solutions and contributed to the technical roadmap.
    </TimeLineElement>
    <TimeLineElement
      title="Engineer III, User Experience"
      subtitle="From Nov 2019 to Mar 2021 at Cisco"
    >
      Focused on building high-performance user interfaces and improving UX for complex systems.
    </TimeLineElement>
    <TimeLineElement
      title="Consultant"
      subtitle="From Jun 2018 to Nov 2019 at DEV6"
    >
      Advised clients on modern web technologies and implemented robust SPA solutions.
    </TimeLineElement>
    <TimeLineElement
      title="Technical Specialist / Senior Analyst Programmer"
      subtitle="From Mar 2015 to May 2018 at Fidelity International"
    >
      Redesigned the Personal Investment module. Worked with architects to implement cloud-based solutions using Node.js, Angular, and MongoDB on AWS.
    </TimeLineElement>
    <TimeLineElement
      title="Software Engineer"
      subtitle="From Dec 2013 to Feb 2015 at Teamware Solutions"
    >
      Contributed to RIA applications using Backbone/Marionette. Focused on unit testing (Mocha) and CI/CD (Grunt).
    </TimeLineElement>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Key Projects</div>
  </div>

  <HorizontalCard
    title="Personal Investment Module Redesign"
    img="/project_placeholder.webp"
    desc="Worked on redesigning the Personal Investment module for Fidelity International. Implemented solutions using Angular, Node.js, and MongoDB, hosted on AWS Cloud."
    url="#"
    badge="Fidelity"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Lanyon Travel Portal"
    img="/project_placeholder.webp"
    desc="Developed and maintained the Lanyon travel portal. Handled bug fixing and feature enhancements using JavaScript and jQuery."
    url="#"
    badge="Cybage"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Tech Data Retail Website"
    img="/project_placeholder.webp"
    desc="Maintained and enhanced the Tech Data retail website. Ensured cross-browser compatibility and optimized performance using HTML, CSS, and jQuery."
    url="#"
    badge="HCL"
  />

  <div class="mb-5 mt-10">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="Masters of Computer Applications"
      subtitle="2005 to 2008 at Anna University, Chennai, India"
    />
    <TimeLineElement
      title="Bachelors of Science"
      subtitle="at International College for Girls, Jaipur, Rajasthan, India"
    />
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Certifications</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2">
    <li>
      MTS: Microsoft® .NET Framework 2.0 - Web-based Client Development
    </li>
    <li>
      Sun Certified Java Programmer for the Java2 Platform, Standard Edition 5.0
    </li>
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Skills</div>
  </div>

  <ul class="list-disc md:columns-5 columns-2 mx-6">
    <li>Angular (7, 4)</li>
    <li>React</li>
    <li>Node.js / Express</li>
    <li>Backbone / Marionette</li>
    <li>HTML5 / CSS3</li>
    <li>JavaScript / jQuery</li>
    <li>TypeScript</li>
    <li>MongoDB / MySQL</li>
    <li>AWS Cloud</li>
    <li>Agile / SCRUM</li>
    <li>TDD (Test Driven Development)</li>
    <li>Git / SVN</li>
    <li>JIRA</li>
    <li>Jenkins / Teamcity</li>
    <li>Design Patterns</li>
  </ul>
</BaseLayout>
